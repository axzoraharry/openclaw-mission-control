      "endpoint": "http://localhost:8001/hp/convert",
      "method": "POST",
      "parameters": {
        "amount": {
          "type": "number",
          "required": true,
          "description": "Amount to convert"
        },
        "from": {
          "type": "string",
          "enum": ["HP", "INR"],
          "required": true,
          "description": "Source currency"
        },
        "to": {
          "type": "string",
          "enum": ["HP", "INR"],
          "required": true,
          "description": "Target currency"
        }
      },
      "agent": "tansi",
      "rate": 1000,
      "examples": [
        {"input": {"amount": 5, "from": "HP", "to": "INR"}, "output": {"amount": 5000, "currency": "INR"}},
        {"input": {"amount": 10000, "from": "INR", "to": "HP"}, "output": {"amount": 10, "currency": "HP"}}
      ]
    },
