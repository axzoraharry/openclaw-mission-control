# Mr Happy AI Agent Service
FROM python:3.12-slim

WORKDIR /app

# Install dependencies
RUN pip install --no-cache-dir \
    fastapi \
    uvicorn \
    httpx \
    websockets \
    requests \
    pydantic

# Copy agent service code
COPY agent_service.py /app/

# Expose port
EXPOSE 8001

# Run the agent service
CMD ["uvicorn", "agent_service:app", "--host", "0.0.0.0", "--port", "8001"]
